{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickPaste",
  "version": "0.1.0",
  "identifier": "com.mamakstudio.quickpaste",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "QuickPaste",
        "width": 380,
        "height": 560,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright © 2026 Emir Han Mamak (Mamak Studio)",
    "publisher": "Mamak Studio",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
